{
    "image": "mcr.microsoft.com/devcontainers/java:17",
    "forwardPorts": [8080],
    "portsAttributes": {
        "8080": {
            "label": "Mon Application Java",
            "visibility": "public"
        }
    },
    "postCreateCommand": "echo '✅ Java 17 installé! Lance ton projet avec: ./mvnw spring-boot:run'",
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack"
            ]
        }
    }
}
