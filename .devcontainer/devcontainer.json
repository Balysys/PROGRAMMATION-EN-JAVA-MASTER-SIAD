{
    "name": "Java GUI Master SIAD",
    "image": "mcr.microsoft.com/devcontainers/java:17-bullseye",
    "features": {
        "ghcr.io/devcontainers/features/desktop-lite:1": {
            "installVnc": true
        }
    },
    "containerEnv": {
        "DISPLAY": ":1"
    },
    "forwardPorts": [6080],
    "onCreateCommand": "sudo rm -f /etc/apt/sources.list.d/yarn.list && sudo apt-get update"
}